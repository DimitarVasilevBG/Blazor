@inherits LayoutComponentBase
@inject AuthenticationStateProvider AuthStateProvider

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="d-flex justify-content-end align-items-center p-2 border-bottom bg-light">
            <!-- Cart button -->
            <a href="/cart" class="btn btn-outline-primary position-relative me-2">
                <span class="me-1">🛒</span> Cart
            </a>

            <AuthorizeView>
                <Authorized>
                    Hello, @context.User.Identity.Name!
                    <form method="post" action="/api/auth/logout" style="display:inline;">
                        <button class="btn btn-sm btn-outline-danger ms-2">Logout</button>
                    </form>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="btn btn-sm btn-outline-primary me-2">Login</a>
                    <a href="/register" class="btn btn-sm btn-outline-secondary">Register</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>